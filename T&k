    return render_template_string(HTML_TEMPLATE, last_img=last_img)

@app.route('/create_bill', methods=['POST'])
def create_bill():
    name = request.form.get('name', 'N/A')
    phone = request.form.get('phone', 'N/A')
    address = request.form.get('address', '')
    device = request.form.get('device', 'N/A')
    job_type = request.form.get('job_type', 'N/A')
    symptom = request.form.get('symptom', '')
    current_date = datetime.now().strftime("%Y-%m-%d %H:%M")
    bill_id = datetime.now().strftime("%d%H%M%S")
    
    items = []
    total_price = 0.0
    for i in range(1, 4):
        item_text = request.form.get(f'item{i}', '')
        item_p = request.form.get(f'p{i}', '0')
        try:
            p_val = float(item_p) if item_p else 0.0
        except:
            p_val = 0.0
        if item_text:
            items.append((item_text, p_val))
            total_price += p_val

    # สร้างรูปภาพ
    img = Image.new('RGB', (550, 1150), color='#FFFFFF')
    draw = ImageDraw.Draw(img)
    
    # ลองใช้ font ตัวหนา หรือ default
    try:
        font_bold = ImageFont.truetype("ThaiFont.ttf", 34)
        font_normal = ImageFont.truetype("ThaiFont.ttf", 24)
        font_small = ImageFont.truetype("ThaiFont.ttf", 20)
    except:
        try:
            font_bold = ImageFont.truetype("/usr/share/fonts/thai/Garuda.ttf", 34)
            font_normal = ImageFont.truetype("/usr/share/fonts/thai/Garuda.ttf", 24)
            font_small = ImageFont.truetype("/usr/share/fonts/thai/Garuda.ttf", 20)
        except:
            font_bold = font_normal = font_small = ImageFont.load_default()
        
    draw.rectangle([(0, 0), (550, 75)], fill='#1E3A8A')
    draw.text((275, 38), "T&K ELECTRICAL SERVICE", fill='#FFFFFF', font=font_bold, anchor="mm")
    
    draw.text((40, 105), "ใบแจ้งซ่อม / ใบรับงาน", fill='#0f172a', font=font_bold)
    draw.text((40, 145), f"เลขที่เอกสาร: TK-{bill_id}", fill='#334155', font=font_normal)
    draw.text((40, 180), f"วันที่ปฏิบัติงาน: {current_date}", fill='#64748b', font=font_normal)
    draw.line([(40, 215), (510, 215)], fill='#cbd5e1', width=2)
    
    draw.text((40, 235), f"ประเภทงาน: {job_type}", fill='#1e3a8a', font=font_bold)
    draw.text((40, 270), f"ลูกค้า: {name}", fill='#334155', font=font_normal)
    draw.text((40, 305), f"เบอร์โทรติดต่อ: {phone}", fill='#334155', font=font_normal)
    if address:
        draw.text((40, 340), f"สถานที่: {address}", fill='#334155', font=font_normal)
        offset_y = 375
    else:
        offset_y = 340
        
    draw.text((40, offset_y), f"อุปกรณ์ที่ให้บริการ: {device}", fill='#334155', font=font_normal)
    draw.text((40, offset_y+35), f"อาการชำรุด: {symptom if symptom else 'ตรวจเช็กสภาพระบบทั่วไป'}", fill='#334155', font=font_normal)
    
    draw.line([(40, offset_y+75), (510, offset_y+75)], fill='#cbd5e1', width=2)
    
    draw.text((40, offset_y+95), "รายละเอียดรายการวัสดุ / ค่าบริการ", fill='#0f172a', font=font_bold)
    y_offset = offset_y + 135
    
    if not items:
        draw.text((40, y_offset), "- ตรวจเช็กสภาพและบำรุงรักษาทั่วไป -", fill='#64748b', font=font_normal)
        y_offset += 35
    else:
        for it_title, it_cost in items:
            draw.text((40, y_offset), f"• {it_title}", fill='#334155', font=font_normal)
            draw.text((510, y_offset), f"{it_cost:,.2f}", fill='#334155', font=font_normal, anchor="ra")
            y_offset += 35
            
    draw.line([(40, y_offset+10), (510, y_offset+10)], fill='#1E3A8A', width=3)
    
    draw.text((40, y_offset+40), "รวมราคาทั้งสิ้นสุทธิ", fill='#0f172a', font=font_bold)
    draw.text((510, y_offset+40), f"{total_price:,.2f} บาท", fill='#1E3A8A', font=font_bold, anchor="ra")
    draw.line([(40, y_offset+75), (510, y_offset+75)], fill='#cbd5e1', width=1)
    
    y_cond = y_offset + 95
    draw.text((40, y_cond), "เงื่อนไขการบริการ", fill='#1e3a8a', font=font_bold)
    
    cond_lines = [
        "1. รับประกันงาน 30 วัน นับจากวันส่งมอบ",
        "2. มัดจำอะไหล่เฉพาะทาง 50% ล่วงหน้า",
        "3. ขอบคุณที่ไว้วางใจ T&K SERVICE"
    ]
    
    y_cond += 35
    for line in cond_lines:
        draw.text((40, y_cond), line, fill='#475569', font=font_small)
        y_cond += 28
    
    # บันทึกรูปภาพ
    filename = f"bill_TK{bill_id}.png"
    filepath = os.path.join('bills', filename)
    img.save(filepath)
    
    return redirect(f"/?last_img={filename}")

@app.route('/get_image/<filename>')
def get_image(filename):
    """ดาวน์โหลดรูปภาพบิล"""
    try:
        return send_file(
            os.path.join('bills', filename),
            mimetype='image/png',
            as_attachment=True,
            download_name=filename
        )
    except FileNotFoundError:
        return "ไฟล์ไม่พบ", 404

if __name__ == '__main__':
    app.run(debug=True, host='0.0.0.0', port=5000)
