@app.route('/create_bill', methods=['POST'])
def create_bill():
    try:
        name = request.form.get('name', 'N/A').strip()
        phone = request.form.get('phone', 'N/A').strip()
        address = request.form.get('address', '').strip()
        device = request.form.get('device', 'N/A').strip()
        job_type = request.form.get('job_type', 'N/A').strip()
        symptom = request.form.get('symptom', '').strip()
        current_date = datetime.now().strftime("%Y-%m-%d %H:%M")
        bill_id = datetime.now().strftime("%d%H%M%S")
        
        items = []
        total_price = 0.0
        for i in range(1, 4):
            item_text = request.form.get(f'item{i}', '').strip()
            item_p = request.form.get(f'p{i}', '0')
            try:
                p_val = float(item_p) if item_p else 0.0
            except (ValueError, TypeError):
                p_val = 0.0
            if item_text:
                items.append((item_text, p_val))
                total_price += p_val

        # สร้างรูปภาพ
        img = Image.new('RGB', (550, 1250), color='white')
        draw = ImageDraw.Draw(img)
        
        # ลองใช้ font ที่รองรับภาษาไทย
        font_bold = font_normal = font_small = None
        font_paths = [
            "/usr/share/fonts/truetype/thai/Garuda.ttf",
            "/usr/share/fonts/truetype/thai/Liberations.ttf",
            "/usr/share/fonts/noto/NotoSansThai-Bold.ttf",
            "/System/Library/Fonts/Arial.ttf",
            "/Windows/Fonts/Arial.ttf",
            "Arial.ttf",
        ]
        
        for font_path in font_paths:
            try:
                if os.path.exists(font_path):
                    font_bold = ImageFont.truetype(font_path, 20)
                    font_normal = ImageFont.truetype(font_path, 16)
                    font_small = ImageFont.truetype(font_path, 12)
                    break
            except (IOError, OSError):
                continue
        
        # ถ้าไม่มีฟอนต์ไหนได้ ใช้ default
        if font_bold is None:
            font_bold = font_normal = font_small = ImageFont.load_default()
            
        # วาดหัวเรื่อง
        draw.rectangle([(0, 0), (550, 70)], fill='#1E3A8A')
        title_text = "T&K ELECTRICAL SERVICE"
        draw.text((275, 35), title_text, fill='white', font=font_bold, anchor="mm")
        
        # วาดข้อมูลทั่วไป
        draw.text((40, 95), "ใบแจ้งซ่อม / ใบรับงาน", fill='#0f172a', font=font_bold)
        draw.text((40, 120), f"เลขที่เอกสาร: TK-{bill_id}", fill='#334155', font=font_normal)
        draw.text((40, 145), f"วันที่ปฏิบัติงาน: {current_date}", fill='#64748b', font=font_normal)
        draw.line([(40, 170), (510, 170)], fill='#cbd5e1', width=2)
        
        draw.text((40, 190), f"ประเภทงาน: {job_type}", fill='#1e3a8a', font=font_bold)
        draw.text((40, 215), f"ลูกค้า: {name}", fill='#334155', font=font_normal)
        draw.text((40, 240), f"เบอร์โทรติดต่อ: {phone}", fill='#334155', font=font_normal)
        
        offset_y = 265
        if address:
            draw.text((40, offset_y), f"สถานที่: {address}", fill='#334155', font=font_normal)
            offset_y = 290
        else:
            offset_y = 265
            
        draw.text((40, offset_y), f"อุปกรณ์ที่ให้บริการ: {device}", fill='#334155', font=font_normal)
        draw.text((40, offset_y+25), f"อาการชำรุด: {symptom if symptom else 'ตรวจเช็กสภาพระบบทั่วไป'}", fill='#334155', font=font_normal)
        
        draw.line([(40, offset_y+55), (510, offset_y+55)], fill='#cbd5e1', width=2)
        
        draw.text((40, offset_y+75), "รายละเอียดรายการวัสดุ / ค่าบริการ", fill='#0f172a', font=font_bold)
        y_offset = offset_y + 105
        
        if not items:
            draw.text((40, y_offset), "- ตรวจเช็กสภาพและบำรุงรักษาทั่วไป -", fill='#64748b', font=font_normal)
            y_offset += 30
        else:
            for it_title, it_cost in items:
                draw.text((40, y_offset), f"• {it_title}", fill='#334155', font=font_normal)
                draw.text((500, y_offset), f"{it_cost:,.2f}", fill='#334155', font=font_normal, anchor="rm")
                y_offset += 30
                
        draw.line([(40, y_offset+10), (510, y_offset+10)], fill='#1E3A8A', width=3)
        
        draw.text((40, y_offset+30), "รวมราคาทั้งสิ้นสุทธิ", fill='#0f172a', font=font_bold)
        draw.text((500, y_offset+30), f"{total_price:,.2f} บาท", fill='#1E3A8A', font=font_bold, anchor="rm")
        draw.line([(40, y_offset+60), (510, y_offset+60)], fill='#cbd5e1', width=1)
        
        y_cond = y_offset + 80
        draw.text((40, y_cond), "เงื่อนไขการบริการ", fill='#1e3a8a', font=font_bold)
        
        cond_lines = [
            "1. รับประกันงาน 30 วัน นับจากวันส่งมอบ",
            "2. มัดจำอะไหล่เฉพาะทาง 50% ล่วงหน้า",
            "3. ขอบคุณที่ไว้วางใจ T&K SERVICE"
        ]
        
        y_cond += 25
        for line in cond_lines:
            draw.text((40, y_cond), line, fill='#475569', font=font_small)
            y_cond += 22
        
        # บันทึกรูปภาพ
        filename = f"bill_TK{bill_id}.png"
        filepath = os.path.join('bills', filename)
        img.save(filepath)
        
        print(f"✅ สร้างบิลสำเร็จ: {filename}")
        return redirect(f"/?last_img={filename}")
    
    except Exception as e:
        print(f"❌ เกิดข้อผิดพลาด: {str(e)}")
        import traceback
        traceback.print_exc()
        return f"เกิดข้อผิดพลาด: {str(e)}", 500

@app.route('/get_image/<filename>')
def get_image(filename):
    """ดาวน์โหลดรูปภาพบิล"""
    # ป้องกัน Path Traversal attack
    if not re.match(r'^bill_TK\d{8}\.png$', filename):
        return "ไฟล์ไม่ถูกต้อง", 400
    
    try:
        filepath = os.path.join('bills', filename)
        # ตรวจสอบว่าไฟล์อยู่ในโฟลเดอร์ bills เท่านั้น
        if not os.path.abspath(filepath).startswith(os.path.abspath('bills')):
            return "ไฟล์ไม่ถูกต้อง", 400
            
        return send_file(
            filepath,
            mimetype='image/png',
            as_attachment=False,
        )
    except FileNotFoundError:
        return "ไฟล์ไม่พบ", 404
    except Exception as e:
        return f"เกิดข้อผิดพลาด: {str(e)}", 500

